{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Live Server",
      "type": "shell",
      "command": "echo 'Please install Live Server extension and use the Go Live button'",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Open in Browser",
      "type": "shell",
      "command": "xdg-open ${workspaceFolder}/index.html || open ${workspaceFolder}/index.html || start ${workspaceFolder}/index.html",
      "problemMatcher": [],
      "presentation": {
        "reveal": "never"
      }
    },
    {
      "label": "Validate HTML Files",
      "type": "shell",
      "command": "echo 'HTML validation - install HTML linter for validation'",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Check for Large Files",
      "type": "shell",
      "windows": {
        "command": "powershell -Command \"Get-ChildItem -Recurse -File | Where-Object {$_.Length -gt 1MB -and $_.FullName -notlike '*\\.git\\*'} | Select-Object FullName,@{Name='Size';Expression={'{0:N2} MB' -f ($_.Length / 1MB)}} | Format-Table -AutoSize\""
      },
      "linux": {
        "command": "find . -type f -size +1M -not -path './.git/*' -exec ls -lh {} \\;"
      },
      "osx": {
        "command": "find . -type f -size +1M -not -path './.git/*' -exec ls -lh {} \\;"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Show Project Structure",
      "type": "shell",
      "windows": {
        "command": "powershell -Command \"Get-ChildItem -Path . -Recurse -Depth 2 | Where-Object {$_.FullName -notlike '*\\.git\\*' -and $_.FullName -notlike '*\\node_modules\\*'} | Select-Object -First 50 | Format-Table -AutoSize\""
      },
      "linux": {
        "command": "tree -L 3 -I 'node_modules|.git' || find . -not -path '*/\\.*' -not -path '*/node_modules/*' | head -50"
      },
      "osx": {
        "command": "tree -L 3 -I 'node_modules|.git' || find . -not -path '*/\\.*' -not -path '*/node_modules/*' | head -50"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    }
  ]
}
